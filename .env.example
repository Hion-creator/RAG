# Mode 1 (hybrid local+cloud): sign in with `ollama signin` and keep localhost host.
# Mode 2 (direct cloud API): set OLLAMA_HOST=https://ollama.com and OLLAMA_API_KEY.

OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=your_ollama_api_key

# For hybrid mode, use any cloud model available in your account.
# Verified in this workspace: qwen3.5:cloud
CHAT_MODEL=qwen3.5:cloud
EMBEDDING_MODEL=embeddinggemma
# Run once before ingest in hybrid mode: ollama pull embeddinggemma

CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
SIMILARITY_THRESHOLD=0.18
